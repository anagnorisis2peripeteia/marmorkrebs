{
  "name": "marmorkrebs",
  "version": "0.2.0",
  "description": "Mutation testing for PRs via crabbox execution environments",
  "type": "module",
  "bin": {
    "marmorkrebs": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "node scripts/run-tests.mjs",
    "check": "tsc --noEmit",
    "lint": "node scripts/lint.mjs",
    "validate:stryker-cxx-provider": "node scripts/validate-stryker-cxx-provider.mjs",
    "validate:provider": "node scripts/validate-provider.mjs",
    "validate:providers": "node scripts/validate-provider.mjs --all"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  }
}